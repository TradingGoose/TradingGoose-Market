# Database (Required)
DATABASE_URL=postgres://postgres:password@localhost:5432/tradinggoose

# Authentication (Required)
BETTER_AUTH_SECRET=your_secret_key  # Use `openssl rand -hex 32` to generate
BETTER_AUTH_URL=http://localhost:3000

# App URL (Required)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internal API access (server-to-server)
INTERNAL_API_SECRET=your_internal_api_secret  # Use `openssl rand -hex 32` to generate

# Billing: TradingGoose Studio URL for usage validation and reporting
OFFICIAL_TG_URL=http://localhost:3000
