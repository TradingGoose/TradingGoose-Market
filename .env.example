# Database (Required)
DATABASE_URL=postgres://postgres:password@localhost:5432/tradinggoose

# Authentication (Required)
BETTER_AUTH_SECRET=your_secret_key  # Use `openssl rand -hex 32` to generate
BETTER_AUTH_URL=http://localhost:3000

# App URL (Required)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internal API access (server-to-server)
INTERNAL_API_SECRET=your_internal_api_secret  # Use `openssl rand -hex 32` to generate
MARKET_RANK_UPDATE_ACCESS_MODE=authenticated  # "authenticated" = API key or internal secret, "service" = internal secret only

# Email (Optional – emails are skipped if not set)
RESEND_API_KEY=re_xxxxx
FROM_EMAIL_ADDRESS=TradingGoose Market <noreply@yourdomain.com>

# Redis (Optional – required for distributed free-tier rate limiting)
# Vercel Redis Cloud injects this automatically. Password is embedded in the URL.
REDIS_URL=redis://default:password@localhost:6379

# Free tier: unauthenticated IP-based access (set to "false" to disable)
MARKET_FREE_TIER_ENABLED=true
MARKET_FREE_TIER_RPM=25       # Max requests per minute per IP
MARKET_FREE_TIER_RPD=500      # Max requests per day per IP

# Billing: TradingGoose Studio URL for usage validation and reporting
OFFICIAL_TG_URL=http://localhost:3000
